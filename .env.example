# SmartUjenzi - Environment Configuration
# Copy this file to .env and fill in your production values.
# Or set these as environment variables in your hosting control panel.

# Application mode: "local" or "production"
APP_ENV=production

# Database connection (for production hosting)
DB_HOST=localhost
DB_NAME=smart_ujenzi
DB_USER=your_db_username
DB_PASS=your_db_password

# Leave empty if using host+user (production)
# Set to /path/to/mysql.sock if using socket (local dev)
DB_SOCKET=
